---
import { siteConfig } from "../../config";
import ForumHomePage from "@/components/forum/pages/ForumHomePage.svelte";
import PageCardHeader from "@components/misc/PageCardHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "首页", item: Astro.site },
		{
			"@type": "ListItem",
			position: 2,
			name: "论坛",
			item: new URL("/forum/", Astro.site).toString(),
		},
	],
};
---

<MainGridLayout title="论坛" description="站内论坛首页，支持独立的环境切换、帖子浏览与互动。">
	<script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
	<div class="p-6 md:p-8 border-b border-white/10">
		<PageCardHeader title="论坛广场" icon="material-symbols:forum-outline-rounded" pathname="/forum/" />
		<ForumHomePage client:only="svelte" />
		<noscript>
			<div class="card-base p-6 md:p-8">
				<div class="mb-6 flex flex-col gap-4">
					<div>
						<p class="text-sm text-white/45">i.{siteConfig.customDomain} 论坛已将前端接入官网，如遇前端Bug，请反馈至 <a href="https://github.com/afoim/fuwari/issues" target="_blank" rel="noreferrer" class="text-[var(--primary)] underline decoration-dashed underline-offset-4">Fuwari</a>，如遇后端Bug，请反馈至 <a href="https://github.com/afoim/acofork_forum_backend/issues" target="_blank" rel="noreferrer" class="text-[var(--primary)] underline decoration-dashed underline-offset-4">acofork_forum_backend</a>。如果你不知道某个Bug是哪个端导致的，可以前往置顶帖评论反馈</p>
					</div>
					<div class="flex flex-wrap gap-3">
						<span class="rounded-xl bg-[var(--primary)] px-4 py-3 text-sm font-bold text-black/80 opacity-50 cursor-not-allowed">发布帖子</span>
						<span class="rounded-xl border border-white/10 px-4 py-3 text-sm font-bold text-white/70 opacity-50 cursor-not-allowed">个人中心</span>
					</div>
				</div>
				<div class="space-y-4">
					<div class="card-base p-5">
						<p class="text-white/50 text-center">启用 JavaScript 后可浏览帖子。</p>
						<p class="text-white/35 text-sm text-center mt-2">如需在无 JS 环境下访问论坛，请使用 <a href="/forum/api/" target="_blank" class="text-[var(--primary)] underline">论坛 API</a>。</p>
					</div>
				</div>
			</div>
		</noscript>
	</div>
</MainGridLayout>
